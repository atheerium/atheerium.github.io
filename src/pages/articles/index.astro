---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Articles">
  <h1>Articles</h1>
  <p style="color: #555; margin-bottom: 1.5rem;">
    Evergreen writing on domain investing, freelancing, automation, and building in public.
  </p>

  {articles.length > 0 ? (
    <ul class="entry-list">
      {articles.map(entry => (
        <li>
          <span class="date">
            {entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            {entry.data.tags.length > 0 && (
              <span class="tags" style="margin-left: 0.5rem;">
                {entry.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </span>
            )}
          </span>
          <a href={`/articles/${entry.id.replace('.md', '')}/`}>{entry.data.title}</a>
          <p class="desc">{entry.data.description}</p>
        </li>
      ))}
    </ul>
  ) : (
    <p style="color: #888;">No articles published yet. Coming soon.</p>
  )}
</Layout>
