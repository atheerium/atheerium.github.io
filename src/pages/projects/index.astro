---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout title="Projects">
  <h1>Projects</h1>
  <p style="color: #555; margin-bottom: 1.5rem;">
    Tools, applications, and systems I've built.
  </p>

  {entries.length > 0 ? (
    <ul class="entry-list">
      {entries.map(entry => (
        <li>
          <span class="date">{entry.data.status} · {entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
          <a href={`/projects/${entry.id.replace('.md', '')}/`}>{entry.data.title}</a>
          <p class="desc">{entry.data.description}</p>
        </li>
      ))}
    </ul>
  ) : (
    <p style="color: #888;">No projects listed yet. Coming soon.</p>
  )}
</Layout>
