---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  pubDate?: Date;
  tags?: string[];
  section?: string;
}

const {
  title,
  description = 'Personal website and knowledge base by Atheerium — domain investing, freelancing, and building in public.',
  image = '/og-default.png',
  pubDate,
  tags = [],
  section,
} = Astro.props;

const siteUrl = 'https://atheerium.github.io';
const canonicalUrl = Astro.url.pathname.endsWith('/')
  ? `${siteUrl}${Astro.url.pathname}`
  : `${siteUrl}${Astro.url.pathname}/`;

// Structured data (JSON-LD) — BlogPosting or WebPage
const structuredData = pubDate
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      datePublished: pubDate.toISOString(),
      url: canonicalUrl,
      author: {
        '@type': 'Person',
        name: 'Atheerium',
        url: siteUrl,
      },
    }
  : {
      '@context': 'https://schema.org',
      '@type': 'WebPage',
      name: title,
      description,
      url: canonicalUrl,
    };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{title} — Atheerium</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Atheerium" />
    <meta property="og:type" content={pubDate ? 'article' : 'website'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />

    <!-- Tags as keywords -->
    {tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- RSS autodiscovery -->
    <link rel="alternate" type="application/rss+xml" title="Atheerium — RSS Feed" href="/rss.xml" />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

    <!-- Robots -->
    <meta name="robots" content="index, follow" />

    <style>
      /* System font stack — minimal, fast */
      html {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen,
          Ubuntu, Cantarell, 'Helvetica Neue', Arial, sans-serif;
        font-size: 16px;
        line-height: 1.7;
        color: #1a1a2e;
        background: #fafafa;
        -webkit-font-smoothing: antialiased;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        padding: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      a {
        color: #2563eb;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      a:visited {
        color: #7c3aed;
      }

      img {
        max-width: 100%;
        height: auto;
      }

      code {
        font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
        font-size: 0.9em;
        background: #e8e8e8;
        padding: 0.15em 0.35em;
        border-radius: 3px;
      }

      pre {
        background: #0d1117;
        color: #e6edf3;
        padding: 1rem;
        border-radius: 8px;
        overflow-x: auto;
      }

      pre code {
        background: none;
        padding: 0;
        font-size: 0.85rem;
      }

      h1, h2, h3, h4 {
        line-height: 1.3;
        margin: 1.5em 0 0.5em;
      }

      h1 { font-size: 2rem; }
      h2 { font-size: 1.5rem; }
      h3 { font-size: 1.25rem; }

      p, ul, ol {
        margin: 0 0 1em;
      }

      blockquote {
        margin: 1em 0;
        padding: 0.5em 1em;
        border-left: 3px solid #2563eb;
        background: #f0f4ff;
      }

      hr {
        border: none;
        border-top: 1px solid #d0d0d0;
        margin: 2em 0;
      }

      /* Navigation */
      nav {
        display: flex;
        gap: 1.5rem;
        padding: 1rem 1.5rem;
        background: #ffffff;
        border-bottom: 1px solid #e0e0e0;
        flex-wrap: wrap;
      }

      nav a {
        color: #444;
        font-size: 0.9rem;
        font-weight: 500;
        text-transform: lowercase;
      }

      nav a:hover,
      nav a.current {
        color: #2563eb;
        text-decoration: none;
      }

      nav .site-title {
        font-weight: 700;
        color: #1a1a2e;
        margin-right: auto;
        text-transform: none;
      }

      /* Main content */
      main {
        flex: 1;
        max-width: 720px;
        width: 100%;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }

      /* Footer */
      footer {
        text-align: center;
        padding: 2rem 1.5rem;
        font-size: 0.8rem;
        color: #888;
        border-top: 1px solid #e0e0e0;
      }

      footer a {
        color: #666;
      }

      /* Article list */
      .entry-list {
        list-style: none;
        padding: 0;
      }

      .entry-list li {
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #e8e8e8;
      }

      .entry-list li:last-child {
        border-bottom: none;
      }

      .entry-list li:hover {
        background: #f5f5f5;
        border-radius: 4px;
      }

      .entry-list .date {
        font-size: 0.8rem;
        color: #666;
        display: block;
        margin-bottom: 0.25rem;
      }

      .entry-list a {
        font-size: 1.1rem;
        font-weight: 600;
      }

      .entry-list .desc {
        font-size: 0.9rem;
        color: #555;
        margin-top: 0.25rem;
      }

      /* Back link */
      .back-link {
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
      }

      .back-link a {
        color: #666;
      }

      .back-link a:hover {
        color: #2563eb;
        text-decoration: none;
      }

      /* Tags */
      .tags {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
        margin-top: 0.5rem;
      }

      .tag {
        font-size: 0.75rem;
        background: #e8e8e8;
        padding: 0.15em 0.5em;
        border-radius: 3px;
        color: #555;
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="site-title">atheerium</a>
      <a href="/articles/">articles</a>
      <a href="/research/">research</a>
      <a href="/projects/">projects</a>
      <a href="/domains/">domains</a>
      <a href="/notes/">notes</a>
      <a href="/about/">about</a>
      <a href="/now/">now</a>
    </nav>

    <main>
      {section && <p class="back-link"><a href="/{section}/">← back to {section}</a></p>}
      <slot />
    </main>

    <footer>
      <p>
        <a href="/">atheerium</a> —
        <a href="/articles/">articles</a> —
        <a href="/research/">research</a> —
        <a href="/projects/">projects</a> —
        <a href="/domains/">domains</a> —
        <a href="/tools/">tools</a> —
        <a href="/resources/">resources</a> —
        <a href="/now/">now</a>
      </p>
      <p style="margin-top: 0.5rem; font-size: 0.75rem;">
        built with <a href="https://astro.build">astro</a> on
        <a href="https://pages.github.com">github pages</a>
      </p>
    </footer>
  </body>
</html>
